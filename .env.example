# Arena MCP Configuration

# Timeout for agent execution (milliseconds)
ARENA_TIMEOUT_MS=120000

# Default number of rounds for debates and challenges
ARENA_DEFAULT_ROUNDS=3

# Default execution mode: "sequential" or "parallel"
ARENA_DEFAULT_MODE=parallel

# Model selection for each agent (optional)
# If not set, the CLI's default model will be used

# Claude model (e.g., claude-sonnet-4-6, claude-opus-4-6)
ARENA_CLAUDE_MODEL=

# Codex model
ARENA_CODEX_MODEL=

# Gemini model (e.g., gemini-pro, gemini-ultra)
ARENA_GEMINI_MODEL=

# OpenAI model (e.g., gpt-4, gpt-4-turbo)
ARENA_OPENAI_MODEL=
