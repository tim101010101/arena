{
  "name": "arena-mcp",
  "version": "0.1.1",
  "description": "Multi-agent AI arena for debates, code reviews, and red-team challenges via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "arena-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "author": "",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "multi-agent",
    "debate",
    "code-review",
    "red-team",
    "claude",
    "openai",
    "gemini"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tim101010101/arena.git"
  },
  "bugs": {
    "url": "https://github.com/tim101010101/arena/issues"
  },
  "scripts": {
    "test": "bun test",
    "test:integration": "bun test tests/integration",
    "build": "bun build src/index.ts --target=bun --outfile=dist/index.js --minify && echo '#!/usr/bin/env bun' | cat - dist/index.js > dist/index.tmp && mv dist/index.tmp dist/index.js && chmod +x dist/index.js",
    "prepare": "bun run build",
    "prepack": "bun run build",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
