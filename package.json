{
  "name": "arena",
  "version": "0.1.1",
  "description": "Multi-agent AI arena for debates, code reviews, and red-team challenges via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "arena": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "author": "tim101010101",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "multi-agent",
    "debate",
    "code-review",
    "red-team",
    "claude",
    "openai",
    "gemini"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tim101010101/arena.git"
  },
  "bugs": {
    "url": "https://github.com/tim101010101/arena/issues"
  },
  "scripts": {
    "test": "bun test",
    "test:integration": "bun test tests/integration",
    "build": "node --input-type=module -e \"\" 2>/dev/null; bun build src/index.ts --target=node --outfile=dist/index.js --minify && printf '#!/usr/bin/env node\\n' | cat - dist/index.js > dist/index.tmp && mv dist/index.tmp dist/index.js && chmod +x dist/index.js",
    "prepare": "bun run build",
    "prepack": "bun run build",
    "start": "node dist/index.js",
    "dev": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
